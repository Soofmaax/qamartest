# Public (exposed to the browser)
# Base path used for GitHub Pages preview builds (ex: "/<repo-name>")
NEXT_PUBLIC_BASE_PATH=

# When set to "1", the site builds as a static export (Next output:export) and is marked noindex.
NEXT_PUBLIC_IS_PREVIEW=0

# Analytics (only loaded after cookie consent)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Optional: external booking link for "Appel découverte" CTAs
NEXT_PUBLIC_DISCOVERY_CALL_URL=

# Server-only (API routes)
RESEND_API_KEY=
RESEND_TO=
RESEND_FROM=
